#!/bin/sh

# Get the commit message from the file argument
commit_msg=$(cat "$1")

# Regex to match strictly: feat:, fix:, chore:, docs:, refactor:, style:, test:
pattern="^(feat|fix|chore|docs|refactor|style|test): "

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "❌ Error: Commit message does not follow the required format."
  echo "Format requirement:"
  echo "  - <type>: <description>"
  echo "Allowed prefixes: feat, fix, chore, docs, refactor, style, test"
  exit 1
fi
